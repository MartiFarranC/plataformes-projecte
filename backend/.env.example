PORT=3002
# UdL tunnel to Ollama API (keep ssh tunnel open)
UNIVERSITY_AI_URL=http://127.0.0.1:11435/api/generate
UNIVERSITY_AI_TOKEN=
OLLAMA_MODEL=llama3.2:3b
AI_TIMEOUT_MS=120000
AI_MAX_RETRIES=2
EMBEDDINGS_ENABLED=true
EMBEDDINGS_URL=http://127.0.0.1:11435/api/embeddings
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_TIMEOUT_MS=30000
EMBEDDINGS_CONCURRENCY=4
EMBEDDINGS_CACHE_FILE=.rag-embeddings-cache.json
